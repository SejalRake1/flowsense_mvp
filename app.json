{
  "expo": {
    "name": "FlowSense",
    "slug": "flowsense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flowsense",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
  "package": "com.flowsense.app"
},
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d26edd8a-35f0-441e-b042-891f67bec2b7"
      }
    }
  }
}
